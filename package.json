{
  "name": "@openfeed-ink/widget",
  "version": "0.1.4",
  "description": "Embeddable feedback, roadmap and changelog widget for OpenFeed — the open source alternative to Canny and Frill. One script tag. Full control from your dashboard.",
  "author": {
    "name": "Ali Amer",
    "email": "aliamer19ali@gmail.com",
    "url": "https://openfeed.ink"
  },
  "license": "AGPL-3.0-only",
  "homepage": "https://openfeed.ink",
  "main": "./dist/npm/index.js",
  "module": "./dist/npm/index.js",
  "types": "./dist/npm/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenFeed-ink/openfeed-widget"
  },
  "bugs": {
    "url": "https://github.com/OpenFeed-ink/openfeed-widget/issues"
  },
  "keywords": [
    "feedback",
    "feedback-widget",
    "changelog",
    "roadmap",
    "feature-requests",
    "upvoting",
    "canny-alternative",
    "frill-alternative",
    "open-source",
    "self-hosted",
    "user-feedback",
    "product-feedback",
    "saas",
    "widget",
    "embeddable",
    "react",
    "typescript"
  ],
  "exports": {
    ".": {
      "import": "./dist/npm/index.js",
      "types": "./dist/npm/index.d.ts"
    }
  },
  "files": [
    "dist/npm",
    "README.md",
    "LICENSE"
  ],
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode cdn && vite build --mode npm",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource-variable/roboto": "^5.2.10",
    "@tailwindcss/vite": "^4.1.17",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^4.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.17",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.5.4"
  }
}
